rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== UTILITY FUNCTIONS =====
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // ===== USERS COLLECTION =====
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && !request.resource.data.keys().hasAny(['coins', 'admin', 'welcomeBonusGranted']);
      
      allow read: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['coins', 'welcomeBonusGranted', 'lastCoinUpdate', 'lastCoinAction']);
    }
    
    // ===== COIN TRANSACTIONS =====
    match /coinTransactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // ===== RECHARGE REQUESTS =====
    match /recharge_requests/{requestId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && hasRequiredFields(['userId', 'amount', 'transactionId', 'status', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 5000;
      allow update, delete: if false;
    }
    
    // ===== SIMULATOR STATE =====
    match /artifacts/{appId}/users/{userId}/simulator/state {
      allow read: if isOwner(userId);
      
      // Owner can write all fields (needed for buy/sell trades)
      // Welcome bonus is protected by 5-layer server-side dedup, not by rules
      allow write: if isOwner(userId);
      
      // Server (admin) can update balance for recharge approvals
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['balance', 'lastBalanceUpdate', 'lastBonusGranted']);
    }
    
    // ===== MARKET DATA (read-only) =====
    match /artifacts/{appId}/public/data/market_info/latest {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    match /artifacts/{appId}/public/data/market_info/categories {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // ===== PUBLIC STATS =====
    match /public_stats/site_stats {
      allow read: if true;
      allow update: if isAuthenticated();
    }
    
    match /public_stats/site_stats/counted_users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if false;
    }
    
    // ===== SERVER-ONLY COLLECTIONS =====
    match /rate_limits/{identifier} {
      allow read, write, delete: if false;
    }
    
    match /_health/test {
      allow read, write, delete: if false;
    }
    
    // ===== SHORT LINKS =====
    match /short_links/{code} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.creatorId);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']);
    }
    
    // ===== DENY ALL OTHER PATHS =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}